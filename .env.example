# ==================== Spring ====================
SPRING_PROFILES_ACTIVE=local

# ==================== Database (Postgres) ====================
# 하이브리드 로컬 개발: localhost (IDE에서 backend 실행)
# 풀 컨테이너 모드: postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soongongjandi
DB_USER=soongongjandi
DB_PASSWORD=changeme

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== JWT (32자 이상 필수) ====================
JWT_SECRET=replace_with_at_least_32_chars_secret_key_for_dev
JWT_ACCESS_EXPIRE=3600000
JWT_REFRESH_EXPIRE=1209600000

# ==================== OAuth (필요 시 채우기) ====================
